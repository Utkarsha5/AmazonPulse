{
  "manifest_version": 3,
  "name": "Amazon Pulse",
  "version": "0.1.0",
  "description": "Pulse UI overlay for Amazon Tez quick-commerce pages.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*.amazon.in/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.in/tez/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
